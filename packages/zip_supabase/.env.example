############################################################
# Zip Captions — Local Supabase Environment Configuration
#
# Copy this file to .env and update values as needed.
#   cp .env.example .env
#
# These are LOCAL DEVELOPMENT defaults only.
# Do NOT use these values in production.
############################################################

# ── Secrets ──────────────────────────────────────────────
# Postgres superuser password
POSTGRES_PASSWORD=your-super-secret-and-long-postgres-password

# JWT signing secret (minimum 32 characters)
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# Anonymous API key (Supabase demo key — safe for local dev only)
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyAgCiAgICAicm9sZSI6ICJhbm9uIiwKICAgICJpc3MiOiAic3VwYWJhc2UtZGVtbyIsCiAgICAiaWF0IjogMTY0MTc2OTIwMCwKICAgICJleHAiOiAxNzk5NTM1NjAwCn0.dc_X5iR_VP_qT0zsiyj_I_OZ2T9FtRU2BBNWN8Bu4GE

# Service role key — bypasses RLS (Supabase demo key — safe for local dev only)
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyAgCiAgICAicm9sZSI6ICJzZXJ2aWNlX3JvbGUiLAogICAgImlzcyI6ICJzdXBhYmFzZS1kZW1vIiwKICAgICJpYXQiOiAxNjQxNzY5MjAwLAogICAgImV4cCI6IDE3OTk1MzU2MDAKfQ.DaYlNEoUrrEn2Ig7tqibS-PHK5vgusbcbo7X36XVt4Q

# Supabase Studio login credentials
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=this_password_is_insecure_and_should_be_updated

# Realtime secret key base
SECRET_KEY_BASE=UpNVntn3cDxHJpq99YMc1T1AQgQpc8kfYTuRgBiYa15BLrx8etQoXz3gZv1/u2oq

# ── Database ─────────────────────────────────────────────
POSTGRES_DB=postgres

# ── URLs ─────────────────────────────────────────────────
# Public API URL (via Kong gateway)
SUPABASE_PUBLIC_URL=http://localhost:54321

# External API URL (used by GoTrue for auth redirects)
API_EXTERNAL_URL=http://localhost:54321

# Application site URL (used by GoTrue for email redirect links)
SITE_URL=http://localhost:3000

# Comma-separated list of additional allowed redirect URLs
ADDITIONAL_REDIRECT_URLS=

# ── Auth ─────────────────────────────────────────────────
# JWT token expiry in seconds (default: 1 hour)
JWT_EXPIRY=3600

# Disable new user registration (default: false)
DISABLE_SIGNUP=false

# Allow email-based signup
ENABLE_EMAIL_SIGNUP=true

# Auto-confirm email addresses (skip verification for local dev)
ENABLE_EMAIL_AUTOCONFIRM=true

# Allow anonymous users
ENABLE_ANONYMOUS_USERS=false

# Phone auth (disabled for local dev)
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false

# ── API (PostgREST) ─────────────────────────────────────
# Schemas exposed via REST API
PGRST_DB_SCHEMAS=public,storage,graphql_public

# ── Edge Functions ───────────────────────────────────────
# Skip JWT verification for local Edge Functions
FUNCTIONS_VERIFY_JWT=false

# ── Studio ───────────────────────────────────────────────
STUDIO_DEFAULT_ORGANIZATION="Zip Captions Dev"
STUDIO_DEFAULT_PROJECT=zip-captions-local
